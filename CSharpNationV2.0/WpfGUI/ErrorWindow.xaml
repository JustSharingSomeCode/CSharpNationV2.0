<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CSharpNationV2._0.WpfGUI"
             xmlns:WpfLightControls="clr-namespace:WpfLightControls;assembly=WpfLightControls" x:Name="Window" x:Class="CSharpNationV2._0.WpfGUI.ErrorWindow"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900" Background="#FF2D2D2D" Loaded="Window_Loaded">
    <Grid>

        <WpfLightControls:LightScrollViewer x:Name="FileNamesSv" Margin="10,10,10,45" CornerRadius="5" VerticalScrollBarVisibility="Auto" Background="#FF3C3C3C"
            ScrollBarBackground="#FF646464" ThumbBrush="#FF969696" HorizontalScrollBarVisibility="Auto">
            <StackPanel x:Name="ErrorLogSp" Height="Auto" Width="Auto"/>
        </WpfLightControls:LightScrollViewer>
        <WpfLightControls:LightButton x:Name="ClearBtn" Content="Clear log" IconText="&#xE729;" IconSize="14" Margin="10,0,10,10" VerticalAlignment="Bottom" Height="30" CornerRadius="5" Background="#FF464646" Click="ClearBtn_Click"/>

    </Grid>
</UserControl>
